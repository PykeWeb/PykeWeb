DISCORD_BOT_TOKEN=
DISCORD_CLIENT_ID=
# Pour un démarrage simple : 1 serveur Discord = 1 groupe tablette
DISCORD_GUILD_ID=
DISCORD_TARGET_GROUP_ID=
# URL de base du site Next.js
DISCORD_API_BASE_URL=http://localhost:3000
# Même secret que DISCORD_BACKEND_SHARED_SECRET côté site
DISCORD_SHARED_SECRET=
# Optionnel: pour slash commands scope guild uniquement
DISCORD_REGISTER_COMMANDS=true
